.venv/
__pycache__/
.pytest_cache/
save.json
.coverage
coverage.xml
*.egg-info/
characters.json
accounts.json
codeforge.db
*.kdbx

# Dated security-patch audit reports (evidence trail; regenerated by `make patch`).
security-evidence/

# Dated ARC runtime-dimension verdicts (evidence trail; regenerated by `make arc-verdicts`).
arc-evidence/

# Exported runtime dependency set for the blocking CVE gate (regenerated by `make audit-runtime`).
runtime-requirements.txt

# Runtime Workshop outputs (generated, reproducible); keep the README tracked.
reports/*
!reports/README.md

# Generated cast sandbox (dry-run output; a cast becomes its own repo elsewhere)
casts/

# Local secrets/config: only .env.example (placeholders) is ever tracked.
.env

# Built docs site (regenerated by `make docs-build` / the Pages workflow).
site/

# The Foundry sandbox: generated candidate files (never promoted automatically).
workspace/

# setuptools build artifacts (from a local pip install/build)
build/
