# CodeForge local config. Copy to .env (git-ignored) and fill in.
# Nothing here is required to run the MUD; these only wake optional surfaces.

# The Architect NPC's brain. Default (unset) is the local rule-based guide,
# which needs no key and never touches the network. Set to "claude" to use the
# Claude-backed Architect (requires the key below and `pip install codeforge[ai]`).
CODEFORGE_ARCHITECT=

# Anthropic API key for the Claude-backed Architect. Read from the environment
# only; never logged, returned, or committed. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=your-key-here  # pragma: allowlist secret

# Override the default database location (containers, a chosen data dir).
# CODEFORGE_DB=/path/to/codeforge.db
